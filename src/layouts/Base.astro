---
import '../styles/global.css';
import Seo from '../components/Seo.astro';

interface Props {
    title?: string | undefined;
    description?: string | undefined;
    image?: string | undefined;
    type?: 'website' | 'article' | 'profile' | undefined;
    noindex?: boolean | undefined;
}

const { title, description, image, type, noindex } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <Seo
            title={title}
            description={description}
            image={image}
            type={type}
            noindex={noindex}
        />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600&family=Sedgwick+Ave+Display&display=swap"
            rel="stylesheet"
        />
        <style is:inline>
            body {
                opacity: 0;
            }
            body.loaded {
                opacity: 1;
                transition: opacity 0.3s ease;
            }
        </style>
    </head>
    <body>
        <slot />
        <script>
            import '../main.ts';
        </script>
    </body>
</html>
