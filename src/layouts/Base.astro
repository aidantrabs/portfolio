---
import '../styles/global.css';
import Seo from '../components/Seo.astro';
import IllustrationDefs from '../components/illustrations/IllustrationDefs.astro';
import LoadingIndicator from '../components/LoadingIndicator.astro';
import AppShell from '../components/AppShell.astro';
import OuterFrame from '../components/OuterFrame.astro';
import SideRail from '../components/SideRail.astro';
import ScrollProgress from '../components/ScrollProgress.astro';
import CursorInk from '../components/CursorInk.astro';

interface Props {
    title?: string | undefined;
    description?: string | undefined;
    image?: string | undefined;
    type?: 'website' | 'article' | 'profile' | undefined;
    noindex?: boolean | undefined;
}

const { title, description, image, type, noindex } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <Seo
            title={title}
            description={description}
            image={image}
            type={type}
            noindex={noindex}
        />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Sedgwick+Ave+Display&display=swap"
            rel="stylesheet"
        />
    </head>
    <body>
        <div class="paper-grain" aria-hidden="true"></div>
        <LoadingIndicator />
        <IllustrationDefs />
        <OuterFrame />
        <ScrollProgress />
        <SideRail />
        <CursorInk />
        <main class="app-bounds">
            <AppShell />
            <slot />
        </main>
        <script>
            import '../lib/scroll';
            import '../lib/init';
        </script>
    </body>
</html>
