---
import '../style.css';

interface Props {
    title?: string;
    description?: string;
}

const { title = 'Aidan Traboulay', description = 'Aidan Traboulay - Designer & Developer' } =
    Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600&family=Sedgwick+Ave+Display&display=swap"
            rel="stylesheet"
        />
        <title>{title}</title>
        <style is:inline>
            body {
                opacity: 0;
            }
            body.loaded {
                opacity: 1;
                transition: opacity 0.3s ease;
            }
        </style>
    </head>
    <body>
        <slot />
        <script>
            import '../main.ts';
        </script>
    </body>
</html>
