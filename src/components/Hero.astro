---
import HeroScene from './illustrations/HeroScene.astro';
---

<section id="top" class="hero">
    <div class="graffiti-bg" aria-hidden="true">aidan</div>

    <div class="hero-scene-wrap" aria-hidden="true">
        <HeroScene />
    </div>

    <div class="hero__center">
        <h1 class="graffiti-name text-accent">
            aidan
            <br />
            traboulay
        </h1>
        <p class="hero__tag">software engineer / building infrastructure</p>
    </div>

    <a href="#about" data-scroll-to="about" class="hero__scroll" aria-label="Scroll to about">
        <span>scroll</span>
        <span class="hero__scroll-arrow" aria-hidden="true">↓</span>
    </a>
</section>
