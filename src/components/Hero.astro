---
const NAV_LINK_CLASS =
    'link-hover text-[11px] font-medium uppercase tracking-[0.2em] text-muted hover:text-theme';
const META_LINK_CLASS =
    'link-hover text-[11px] font-medium uppercase tracking-[0.15em] text-muted hover:text-theme';
---

<section class="relative h-screen-safe p-6 md:p-10 lg:p-12">
    <nav
        class="absolute top-6 right-12 md:top-10 md:right-16 lg:top-12 lg:right-20 flex gap-6 md:gap-8"
    >
        <a href="#" data-scroll-to="about" class={NAV_LINK_CLASS}>About</a>
        <a href="https://github.com/aidantrabs" target="_blank" rel="noopener" class={NAV_LINK_CLASS}
            >Projects</a
        >
        <a
            href="https://blog.aidantraboulay.dev"
            target="_blank"
            rel="noopener"
            class={NAV_LINK_CLASS}
        >
            Blog
        </a>
    </nav>

    <div class="graffiti-bg" aria-hidden="true">aidan</div>

    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2">
        <h1 class="graffiti-name text-accent">
            aidan
            <br />
            traboulay
        </h1>
    </div>

    <div class="absolute bottom-6 left-6 right-6 md:hidden">
        <div class="mb-4">
            <p class="text-[9px] font-semibold uppercase tracking-[0.2em] text-muted mb-1">
                Say Hello
            </p>
            <a
                href="mailto:aidantraboulay@protonmail.com"
                class="link-hover text-[11px] font-medium hover:text-accent"
            >
                aidantraboulay@protonmail.com
            </a>
        </div>

        <div class="flex gap-4">
            <a
                href="https://github.com/aidantrabs"
                target="_blank"
                rel="noopener"
                class={META_LINK_CLASS}>GitHub</a
            >
            <a
                href="https://linkedin.com/in/aidan-traboulay"
                target="_blank"
                rel="noopener"
                class={META_LINK_CLASS}>LinkedIn</a
            >
            <a
                href="https://blog.aidantraboulay.dev"
                target="_blank"
                rel="noopener"
                class={META_LINK_CLASS}>Blog</a
            >
        </div>
    </div>

    <div class="absolute bottom-10 left-10 lg:bottom-12 lg:left-12 hidden md:block">
        <p class="text-[9px] font-semibold uppercase tracking-[0.2em] text-muted mb-1">Say Hello</p>
        <a
            href="mailto:aidantraboulay@protonmail.com"
            class="link-hover text-[11px] font-medium hover:text-accent"
        >
            aidantraboulay@protonmail.com
        </a>
    </div>

    <div class="absolute bottom-10 right-10 lg:bottom-12 lg:right-12 hidden md:flex gap-6">
        <a
            href="https://github.com/aidantrabs"
            target="_blank"
            rel="noopener"
            class={META_LINK_CLASS}>GitHub</a
        >
        <a
            href="https://linkedin.com/in/aidan-traboulay"
            target="_blank"
            rel="noopener"
            class={META_LINK_CLASS}>LinkedIn</a
        >
        <a
            href="https://blog.aidantraboulay.dev"
            target="_blank"
            rel="noopener"
            class={META_LINK_CLASS}>Blog</a
        >
    </div>

    <div class="absolute top-6 left-6 md:top-10 md:left-10 lg:top-12 lg:left-12 hidden md:block">
        <p class="text-[9px] font-medium uppercase tracking-[0.2em] text-muted">
            <span class="text-accent">~7kb&nbsp;</span>gzip
        </p>
        <p class="text-[9px] font-medium uppercase tracking-[0.2em] text-muted mt-1">
            Cloudflare <span class="text-accent">/&nbsp;</span>edge
        </p>
    </div>

    <div class="absolute bottom-10 left-1/2 animate-scroll-hint hidden md:block">
        <span class="text-[9px] font-medium uppercase tracking-[0.3em] text-muted">Scroll</span>
    </div>
</section>
