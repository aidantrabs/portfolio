---
---

<section id="top" class="hero">
    <div class="hero__display" data-hero-display>
        <div class="hero-scene" data-hero-scene>
            <div class="hero-scene__stage" data-hero-stage>
                <span class="hero-scene__accent hero-scene__accent--bar" aria-hidden="true"></span>
                <span class="hero-scene__accent hero-scene__accent--ring" aria-hidden="true"></span>
                <span class="hero-scene__accent hero-scene__accent--dot" aria-hidden="true"></span>
                <span class="hero-scene__accent hero-scene__accent--dot-tl" aria-hidden="true"></span>
                <span class="hero-scene__accent hero-scene__accent--dot-br" aria-hidden="true"></span>
                <span class="hero-scene__accent hero-scene__accent--cross" aria-hidden="true">+</span>

                <div class="hero-scene__layer hero-scene__layer--ghost" aria-hidden="true">
                    <span class="hero-scene__line">aidan</span>
                    <span class="hero-scene__line">traboulay</span>
                </div>
                <div class="hero-scene__layer hero-scene__layer--back" aria-hidden="true">
                    <span class="hero-scene__line">aidan</span>
                    <span class="hero-scene__line">traboulay</span>
                </div>
                <div class="hero-scene__layer hero-scene__layer--mid" aria-hidden="true">
                    <span class="hero-scene__line">aidan</span>
                    <span class="hero-scene__line">traboulay</span>
                </div>
                <h1 class="hero-scene__layer hero-scene__layer--front">
                    <span class="hero-scene__line">aidan<span class="hero-scene__dot">.</span></span>
                    <span class="hero-scene__line">traboulay</span>
                </h1>
            </div>
            <span class="hero-scene__hint" data-hero-hint>
                <span class="hero-scene__hint-dot" aria-hidden="true"></span>
                <span>move / click to interact</span>
            </span>
        </div>
    </div>

    <div class="hero__bottombar" data-hero-bottombar>
        <div class="hero__data">
            <span class="hero__data-label">based</span>
            <span class="hero__data-value">trinidad and tobago</span>
        </div>
        <div class="hero__data">
            <span class="hero__data-label">building since</span>
            <span class="hero__data-value">2019</span>
        </div>
        <div class="hero__data hero__data--accent">
            <span class="hero__data-label">status</span>
            <span class="hero__data-value">
                <span class="hero__data-pulse" aria-hidden="true"></span>
                open to work
            </span>
        </div>
    </div>

    <a
        href="#about"
        data-scroll-to="about"
        class="hero__scroll"
        aria-label="Scroll to about"
        data-hero-scroll
    >
        <span>scroll</span>
        <span class="hero__scroll-arrow" aria-hidden="true">↓</span>
    </a>
</section>
