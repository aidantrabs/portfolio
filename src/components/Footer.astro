---
const META_LINK_CLASS =
    'link-hover text-[11px] font-medium uppercase tracking-[0.15em] text-muted hover:text-theme';
const year = new Date().getFullYear();
---

<footer class="px-6 md:px-10 lg:px-12 py-12 md:py-16 lg:py-20">
    <div
        class="relative flex flex-col items-center text-center md:flex-row md:items-end md:justify-between md:text-left gap-8"
    >
        <div>
            <p class="text-[13px] font-semibold uppercase tracking-[0.15em]">
                &copy; Aidan Traboulay
            </p>
            <p class="text-[11px] font-medium uppercase tracking-[0.15em] text-muted mt-1">
                {year}
            </p>
        </div>

        <p
            class="hidden lg:block text-[9px] font-medium uppercase tracking-[0.2em] text-muted absolute left-1/2 -translate-x-1/2 bottom-0"
        >
            proud contributer to technical debt worldwide
        </p>

        <div class="flex gap-6">
            <a href="mailto:aidantraboulay@protonmail.com" class={META_LINK_CLASS}>Email</a>
            <a
                href="https://github.com/aidantrabs"
                target="_blank"
                rel="noopener"
                class={META_LINK_CLASS}>GitHub</a
            >
            <a
                href="https://linkedin.com/in/aidan-traboulay"
                target="_blank"
                rel="noopener"
                class={META_LINK_CLASS}>LinkedIn</a
            >
            <a
                href="https://blog.aidantraboulay.dev"
                target="_blank"
                rel="noopener"
                class={META_LINK_CLASS}>Blog</a
            >
        </div>
    </div>

    <p
        class="lg:hidden text-[9px] font-medium uppercase tracking-[0.2em] text-muted mt-8 text-center"
    >
        proud contributer to technical debt worldwide
    </p>
</footer>
