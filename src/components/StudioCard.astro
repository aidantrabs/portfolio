---
interface Props {
    title: string;
    tagline: string;
    description: string;
    url: string;
}

const { title, tagline, description, url } = Astro.props;

let handle = '';
try {
    const parsed = new URL(url);
    if (parsed.hostname.includes('github.com')) {
        const seg = parsed.pathname.split('/').filter(Boolean)[0];
        if (seg) handle = `@${seg}`;
    }
} catch {
    handle = '';
}
---

<li class="studio-card">
    <a href={url} target="_blank" rel="noopener" class="studio-card__link">
        <div class="studio-card__head">
            <h3 class="studio-card__title">{title}</h3>
            <span class="studio-card__arrow" aria-hidden="true">↗</span>
        </div>
        <p class="studio-card__tagline">{tagline}</p>
        <p class="studio-card__desc">{description}</p>
        <div class="studio-card__foot">
            <span>github</span>
            <span class="studio-card__handle">{handle}</span>
        </div>
    </a>
</li>
