---
import HankoMark from './HankoMark.astro';
---

<div class="app-shell" aria-hidden="true">
    <div class="app-shell__corner app-shell__corner--top-left">
        <a href="#top" data-scroll-to="top" class="app-shell__brand" aria-label="Top">
            <span class="app-shell__brand-mark">
                <HankoMark label="AT" size={44} />
            </span>
        </a>
    </div>

    <div class="app-shell__corner app-shell__corner--top-right">
        <div class="app-shell__socials">
            <a
                href="https://github.com/aidantrabs"
                target="_blank"
                rel="noopener"
                class="app-shell__pill"
            >
                github
                <span aria-hidden="true">↗</span>
            </a>
            <a
                href="https://linkedin.com/in/aidan-traboulay"
                target="_blank"
                rel="noopener"
                class="app-shell__pill"
            >
                linkedin
                <span aria-hidden="true">↗</span>
            </a>
        </div>
    </div>

    <div class="app-shell__corner app-shell__corner--bottom-left">
        <div class="app-shell__id">
            <span>aidan traboulay</span>
            <span>portfolio / vol.iii</span>
            <span class="app-shell__id-meta">~28kb / cf edge</span>
        </div>
    </div>
</div>
