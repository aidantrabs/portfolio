---
import projects from '../content/projects.json';
import ProjectRow from './ProjectRow.astro';

const items = projects as Array<{
    title: string;
    year: number;
    role: string;
    description: string;
    url: string;
    glyph: string;
}>;
---

<section id="work" class="section section--projects">
    <div class="section__header">
        <div class="section__heading">
            <span class="section__num">02</span>
            <h2 class="section__title">work</h2>
        </div>
        <span class="section__count">
            {items.length}
            <span class="section__count-label">/ selected</span>
        </span>
    </div>

    <ol class="projects-list">
        {
            items.map((project, i) => (
                <ProjectRow
                    index={i + 1}
                    title={project.title}
                    year={project.year}
                    role={project.role}
                    description={project.description}
                    url={project.url}
                />
            ))
        }
    </ol>
</section>
