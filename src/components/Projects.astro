---
import projects from '../content/projects.json';
import studios from '../content/studios.json';
import ProjectRow from './ProjectRow.astro';
import StudioCard from './StudioCard.astro';

const personalItems = projects as Array<{
    title: string;
    year: number;
    role: string;
    description: string;
    url: string;
    glyph: string;
}>;

const studioItems = studios as Array<{
    title: string;
    tagline: string;
    description: string;
    url: string;
}>;
---

<section id="work" class="section section--projects">
    <div class="section__header">
        <h2 class="section__title" data-section-title>work</h2>
        <span class="section__count">
            {personalItems.length + studioItems.length}
            <span class="section__count-label">selected</span>
        </span>
    </div>

    <div class="work-group">
        <div class="work-group__label">
            <span>studios</span>
            <span class="work-group__label-tick" aria-hidden="true"></span>
        </div>
        <ul class="studios-grid">
            {
                studioItems.map((studio) => (
                    <StudioCard
                        title={studio.title}
                        tagline={studio.tagline}
                        description={studio.description}
                        url={studio.url}
                    />
                ))
            }
        </ul>
    </div>

    <div class="work-group">
        <div class="work-group__label">
            <span>personal projects</span>
            <span class="work-group__label-tick" aria-hidden="true"></span>
        </div>
        <ol class="projects-list">
            {
                personalItems.map((project) => (
                    <ProjectRow
                        title={project.title}
                        year={project.year}
                        role={project.role}
                        description={project.description}
                        url={project.url}
                    />
                ))
            }
        </ol>
    </div>
</section>
