---
import projects from '../content/projects.json';
import studios from '../content/studios.json';
import WorkRow from './WorkRow.astro';
import Spot from './illustrations/Spot.astro';

type Glyph = 'server' | 'cli' | 'web' | 'tools' | 'data' | 'experiment';

const personalItems = projects as Array<{
    title: string;
    year: number;
    role: string;
    description: string;
    url: string;
    glyph: Glyph;
}>;

const studioItems = studios as Array<{
    title: string;
    tags: string[];
    glyph: Glyph;
    url: string;
}>;

function tagsFromRole(role: string): string[] {
    return role
        .split('/')
        .map((s) => s.trim())
        .filter(Boolean);
}

function handleFromUrl(url: string): string {
    try {
        const parsed = new URL(url);
        if (parsed.hostname.includes('github.com')) {
            const seg = parsed.pathname.split('/').filter(Boolean)[0];
            if (seg) return `@${seg}`;
        }
    } catch {
        // ignore
    }
    return '';
}
---

<section id="work" class="section section--projects">
    <Spot variant="tower" class="section__spot section__spot--work" />
    <div class="section__header">
        <div class="section__eyebrow">
            <span class="section__eyebrow-folio">no. 02</span>
            <span class="section__eyebrow-divider" aria-hidden="true"></span>
            <span class="section__eyebrow-label">a few highlights</span>
        </div>
        <h2 class="section__title" data-section-title>work</h2>
        <span class="section__count">(pickup works)</span>
    </div>

    <div class="work-group">
        <div class="work-group__label">
            <span>studios</span>
            <span class="work-group__label-tick" aria-hidden="true"></span>
        </div>
        <ul class="work-list">
            {
                studioItems.map((studio) => (
                    <WorkRow
                        title={studio.title}
                        tags={studio.tags}
                        glyph={studio.glyph}
                        url={studio.url}
                        handle={handleFromUrl(studio.url)}
                    />
                ))
            }
        </ul>
    </div>

    <div class="work-group">
        <div class="work-group__label">
            <span>personal projects</span>
            <span class="work-group__label-tick" aria-hidden="true"></span>
        </div>
        <ul class="work-list">
            {
                personalItems.map((project) => (
                    <WorkRow
                        title={project.title}
                        tags={tagsFromRole(project.role)}
                        glyph={project.glyph}
                        url={project.url}
                    />
                ))
            }
        </ul>
    </div>
</section>
