    <path
        d="M2 14 C 14 6, 28 18, 46 11 C 64 5, 82 17, 102 12 C 124 7, 144 19, 162 13 C 178 8, 188 16, 198 11 L 197 17 C 184 22, 168 14, 152 19 C 134 24, 116 12, 96 18 C 76 23, 56 11, 38 17 C 22 22, 12 14, 4 19 Z"
        fill="currentColor"
