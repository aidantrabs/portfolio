---
import Spot from './illustrations/Spot.astro';
---

<section id="contact" class="section section--contact">
    <Spot variant="path" class="section__spot section__spot--contact" />
    <div class="section__header">
        <div class="section__eyebrow">
            <span class="section__eyebrow-folio">no. 03</span>
            <span class="section__eyebrow-divider" aria-hidden="true"></span>
            <span class="section__eyebrow-label">say hello</span>
        </div>
        <h2 class="section__title" data-section-title>contact</h2>
    </div>

    <div class="contact-grid">
        <div class="contact__main fade-in-up-target">
            <p class="contact__lede">
                <span class="contact__lede-em">currently open to work.</span> available for full-time and
                contract roles in infrastructure, platform, and full-stack engineering. remote or on-site in
                trinidad and tobago, canada, and the united states.
            </p>

            <div class="contact__cta-row">
                <a
                    href="mailto:aidantraboulay@protonmail.com"
                    class="contact__cta contact__cta--primary"
                >
                    <span>send a message</span>
                    <span aria-hidden="true">→</span>
                </a>
                <a
                    href="https://linkedin.com/in/aidan-traboulay"
                    target="_blank"
                    rel="noopener"
                    class="contact__cta"
                >
                    <span>linkedin</span>
                    <span aria-hidden="true">↗</span>
                </a>
                <a
                    href="https://github.com/aidantrabs"
                    target="_blank"
                    rel="noopener"
                    class="contact__cta"
                >
                    <span>github</span>
                    <span aria-hidden="true">↗</span>
                </a>
            </div>
        </div>

        <aside class="contact__aside fade-in-up-target">
            <div class="contact__aside-item">
                <span class="contact__aside-label">availability</span>
                <span class="contact__aside-value contact__aside-status">
                    <span class="contact__aside-status-dot" aria-hidden="true"></span>
                    open to work
                </span>
            </div>
            <div class="contact__aside-item">
                <span class="contact__aside-label">timezone</span>
                <span class="contact__aside-value">AST · UTC-4</span>
            </div>
            <div class="contact__aside-item">
                <span class="contact__aside-label">response</span>
                <span class="contact__aside-value">within 24 hours</span>
            </div>
        </aside>
    </div>
</section>
