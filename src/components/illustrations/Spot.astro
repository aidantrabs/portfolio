---
type SpotVariant =
    | 'horizon'
    | 'desk'
    | 'tower'
    | 'path'
    | 'mountains'
    | 'palm'
    | 'bird'
    | 'grass'
    | 'sun'
    | 'pine'
    | 'cloud'
    | 'kite'
    | 'shore';

interface Props {
    class?: string | undefined;
    variant: SpotVariant;
    flip?: boolean | undefined;
}
const { class: className = '', variant, flip = false } = Astro.props;
