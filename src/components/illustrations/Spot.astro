        <line x1="20" y1="220" x2="180" y2="220" stroke="currentColor" stroke-width="1" />

        <path
            d="M 100 20 L 130 220 L 70 220 Z"
            fill="none"
            stroke="currentColor"
            stroke-width="1.2"
        />
        <g stroke="currentColor" stroke-width="0.7" fill="none" opacity="0.55">
            <line x1="78" y1="60" x2="122" y2="60" />
            <line x1="74" y1="100" x2="126" y2="100" />
            <line x1="70" y1="140" x2="130" y2="140" />
            <line x1="68" y1="180" x2="132" y2="180" />
        </g>
        <g stroke="currentColor" stroke-width="0.5" fill="none" opacity="0.45">
            <line x1="80" y1="60" x2="84" y2="100" />
            <line x1="120" y1="60" x2="116" y2="100" />
            <line x1="74" y1="100" x2="78" y2="140" />
            <line x1="126" y1="100" x2="122" y2="140" />
            <line x1="70" y1="140" x2="76" y2="180" />
            <line x1="130" y1="140" x2="124" y2="180" />
        </g>

        <line x1="100" y1="20" x2="100" y2="10" stroke="currentColor" stroke-width="1" />
        <circle cx="100" cy="8" r="3" fill="var(--accent-emphasis)" stroke="currentColor" stroke-width="0.8" />

        <g stroke="currentColor" stroke-width="0.6" opacity="0.5" fill="none">
            <path d="M 40 224 L 50 224 M 60 226 L 70 226 M 140 226 L 150 226 M 160 224 L 172 224" />
        </g>
    </g>
</svg>
)}

{variant === 'path' && (
<svg
    class:list={['spot', `spot--${variant}`, className]}
    viewBox="0 0 320 180"
    fill="none"
    aria-hidden="true"
    focusable="false"
>
    <g filter="url(#rough-soft)">
        <path
            d="M 10 160 C 60 150, 120 140, 160 110 C 200 80, 240 70, 290 60"
            fill="none"
            stroke="currentColor"
            stroke-width="1.4"
        />
        <path
            d="M 40 162 C 80 152, 130 142, 170 112 C 210 82, 250 72, 300 62"
            fill="none"
            stroke="currentColor"
            stroke-width="0.8"
            opacity="0.55"
            stroke-dasharray="3 4"
        />

        <path
            d="M 100 130 L 96 100 M 104 130 L 108 102 M 112 130 L 110 108"
            fill="none"
            stroke="currentColor"
            stroke-width="0.9"
            opacity="0.6"
        />
        <path
            d="M 230 90 L 226 60 M 234 90 L 238 62 M 242 90 L 240 70"
            fill="none"
            stroke="currentColor"
            stroke-width="0.9"
            opacity="0.6"
        />

        <line x1="270" y1="70" x2="270" y2="50" stroke="currentColor" stroke-width="1.2" />
        <path
            d="M 270 36 L 278 42 L 270 48 Z"
            fill="var(--accent-emphasis)"
            stroke="currentColor"
            stroke-width="0.9"
            stroke-linejoin="round"
        />

        <g stroke="currentColor" stroke-width="0.5" fill="none" opacity="0.35">
            <path d="M 20 168 L 36 168 M 60 170 L 78 170 M 140 158 L 152 158 M 200 130 L 212 130 M 260 100 L 274 100" />
        </g>
    </g>
</svg>
)}

{variant === 'mountains' && (
<svg
    class:list={['spot', `spot--${variant}`, className]}
    viewBox="0 0 320 180"
    fill="none"
    aria-hidden="true"
    focusable="false"
>
    <g filter="url(#rough-soft)">
        <path
            d="M 0 150 L 60 70 L 100 110 L 160 40 L 220 100 L 270 70 L 320 130 L 320 180 L 0 180 Z"
            fill="none"
            stroke="currentColor"
            stroke-width="1.2"
            stroke-linejoin="round"
        />

        <path
            d="M 142 70 L 160 40 L 178 70"
            fill="none"
            stroke="currentColor"
            stroke-width="1"
        />

        <g stroke="currentColor" stroke-width="0.5" fill="none" opacity="0.45">
            <path d="M 60 82 L 50 100 M 64 88 L 56 104 M 100 116 L 90 130 M 160 60 L 152 78 M 164 62 L 156 80 M 220 110 L 212 124 M 270 80 L 262 96 M 274 82 L 266 100" />
        </g>

        <g transform="translate(258, 22)">
            <path
                d="M 0 18 C 0 8, 18 8, 18 18 C 18 24, 14 28, 10 30 L 8 30 C 4 28, 0 24, 0 18 Z"
                fill="var(--accent-emphasis)"
                stroke="currentColor"
                stroke-width="0.9"
            />
            <line x1="6" y1="30" x2="6" y2="38" stroke="currentColor" stroke-width="0.7" />
            <line x1="12" y1="30" x2="12" y2="38" stroke="currentColor" stroke-width="0.7" />
            <rect x="6" y="38" width="6" height="3" fill="none" stroke="currentColor" stroke-width="0.7" />
        </g>

        <g stroke="currentColor" stroke-width="0.4" fill="none" opacity="0.4">
            <path d="M 20 158 L 32 158 M 50 162 L 64 162 M 100 158 L 116 158 M 180 156 L 196 156 M 240 160 L 256 160 M 282 158 L 298 158" />
        </g>
