        <path
            d="M 40 130 L 38 110 M 42 130 L 44 112 M 50 132 L 48 118 M 56 130 L 60 114"
            fill="none"
            stroke="currentColor"
            stroke-width="0.9"
            opacity="0.65"
        />
        <path
            d="M 168 122 L 166 100 M 172 122 L 176 102 M 180 122 L 178 108 M 188 122 L 192 104"
            fill="none"
            stroke="currentColor"
            stroke-width="0.9"
            opacity="0.65"
        />

        <path
            d="M 110 156 C 130 152, 150 152, 175 156 C 200 160, 235 160, 275 156 C 310 152, 340 154, 358 158"
            fill="none"
            stroke="currentColor"
            stroke-width="1"
            opacity="0.7"
        />

        <g transform="translate(108, 36)">
            <path
                d="M 0 22 C 0 8, 22 8, 22 22 C 22 28, 18 32, 14 34 L 8 34 C 4 32, 0 28, 0 22 Z"
                fill="var(--accent-emphasis)"
                stroke="currentColor"
                stroke-width="0.9"
            />
            <path
                d="M 2 22 L 20 22 M 4 14 L 18 14 M 6 28 L 16 28 M 11 8 L 11 34"
                stroke="currentColor"
                stroke-width="0.7"
                opacity="0.7"
                fill="none"
            />
            <line x1="6" y1="34" x2="8" y2="42" stroke="currentColor" stroke-width="0.7" />
            <line x1="16" y1="34" x2="14" y2="42" stroke="currentColor" stroke-width="0.7" />
            <rect x="8" y="42" width="6" height="4" fill="none" stroke="currentColor" stroke-width="0.7" />
        </g>

        <g stroke="currentColor" stroke-width="0.6" fill="none" opacity="0.35">
            <path d="M 80 160 L 84 160 M 96 164 L 100 164 M 116 168 L 120 168 M 200 158 L 204 158 M 232 156 L 236 156 M 268 160 L 272 160 M 312 162 L 316 162" />
        </g>
    </g>
</svg>
)}

{variant === 'desk' && (
<svg
    class:list={['spot', `spot--${variant}`, className]}
    viewBox="0 0 280 220"
    fill="none"
    aria-hidden="true"
    focusable="false"
>
    <g filter="url(#rough-soft)">
        <line x1="20" y1="156" x2="260" y2="156" stroke="currentColor" stroke-width="1.4" />
        <line x1="20" y1="158" x2="260" y2="158" stroke="currentColor" stroke-width="0.6" opacity="0.6" />

        <rect x="60" y="100" width="100" height="56" fill="var(--bg)" stroke="currentColor" stroke-width="1.2" />
        <rect x="66" y="106" width="88" height="44" fill="none" stroke="currentColor" stroke-width="0.7" opacity="0.55" />
        <g stroke="currentColor" stroke-width="0.5" fill="none" opacity="0.45">
            <line x1="72" y1="116" x2="138" y2="116" />
            <line x1="72" y1="124" x2="120" y2="124" />
            <line x1="72" y1="132" x2="142" y2="132" />
            <line x1="72" y1="140" x2="110" y2="140" />
        </g>

        <rect x="170" y="120" width="44" height="36" fill="var(--bg)" stroke="currentColor" stroke-width="1.2" />
        <g stroke="currentColor" stroke-width="0.5" opacity="0.5" fill="none">
            <line x1="176" y1="128" x2="208" y2="128" />
            <line x1="176" y1="135" x2="200" y2="135" />
            <line x1="176" y1="142" x2="206" y2="142" />
            <line x1="176" y1="149" x2="190" y2="149" />
        </g>

        <line x1="30" y1="100" x2="30" y2="156" stroke="currentColor" stroke-width="1.2" />
        <line x1="30" y1="100" x2="46" y2="60" stroke="currentColor" stroke-width="1.2" />
        <path d="M 22 60 L 46 60 L 50 80 L 18 80 Z" fill="var(--accent-emphasis)" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round" />
        <g stroke="currentColor" stroke-width="0.4" opacity="0.45" fill="none">
            <line x1="24" y1="68" x2="46" y2="68" />
            <line x1="22" y1="74" x2="48" y2="74" />
        </g>

        <circle cx="232" cy="148" r="8" fill="var(--bg)" stroke="currentColor" stroke-width="1" />
        <line x1="232" y1="142" x2="232" y2="148" stroke="currentColor" stroke-width="1" />
        <line x1="232" y1="148" x2="236" y2="150" stroke="currentColor" stroke-width="1" />

        <g stroke="currentColor" stroke-width="0.5" opacity="0.4" fill="none">
            <path d="M 60 168 L 68 168 M 80 172 L 96 172 M 120 170 L 132 170 M 180 168 L 192 168 M 220 170 L 232 170" />
        </g>
    </g>
</svg>
)}

{variant === 'tower' && (
<svg
    class:list={['spot', `spot--${variant}`, className]}
    viewBox="0 0 200 260"
    fill="none"
    aria-hidden="true"
    focusable="false"
>
