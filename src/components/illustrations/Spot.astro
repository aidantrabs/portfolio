---
type SpotVariant =
    | 'horizon'
    | 'desk'
    | 'tower'
    | 'path'
    | 'mountains';

interface Props {
    class?: string | undefined;
    variant: SpotVariant;
    flip?: boolean | undefined;
}
const { class: className = '', variant, flip = false } = Astro.props;
---

{variant === 'horizon' && (
<svg
    class:list={['spot', `spot--${variant}`, flip && 'spot--flip', className]}
    viewBox="0 0 360 200"
    fill="none"
    aria-hidden="true"
    focusable="false"
>
    <g filter="url(#rough-soft)">
        <circle cx="290" cy="78" r="28" fill="none" stroke="currentColor" stroke-width="1" opacity="0.45" />

        <g stroke="currentColor" stroke-width="0.7" fill="none" opacity="0.55">
            <path d="M 270 60 L 282 60 M 268 66 L 284 66 M 266 72 L 286 72 M 264 78 L 288 78 M 266 84 L 286 84 M 268 90 L 284 90 M 270 96 L 282 96" />
        </g>

        <path
            d="M 0 150 C 30 120, 60 110, 90 130 C 110 142, 130 140, 150 130 C 180 115, 210 108, 230 125 C 250 142, 290 145, 320 130 C 340 120, 360 125, 360 130 L 360 200 L 0 200 Z"
            fill="none"
            stroke="currentColor"
            stroke-width="1.2"
        />
        <g stroke="currentColor" stroke-width="0.6" fill="none" opacity="0.5">
            <path d="M 12 162 L 28 158 M 42 168 L 58 164 M 76 158 L 92 154 M 108 162 L 124 158 M 138 154 L 154 150 M 168 148 L 184 144 M 198 144 L 214 140 M 230 142 L 246 138 M 258 138 L 274 134 M 286 136 L 302 132 M 314 132 L 330 130 M 340 128 L 354 128" />
