---
interface Props {
    class?: string | undefined;
}

const { class: className = '' } = Astro.props;
---

<svg
    viewBox="0 0 600 60"
    preserveAspectRatio="none"
    class:list={['illustration', 'circuit-doodle', className]}
    aria-hidden="true"
    focusable="false"
    xmlns="http://www.w3.org/2000/svg"
>
    <g class="circuit-doodle__lines">
        <path
            d="M0 30 L60 30 L70 20 L130 20 L140 30 L240 30"
            class="illustration-stroke"
            stroke-width="1.5"
        ></path>
        <path
            d="M340 30 L420 30 L430 40 L500 40 L510 30 L600 30"
            class="illustration-stroke"
            stroke-width="1.5"
        ></path>
        <path
            d="M70 20 L70 6 M140 30 L140 50 L160 50"
            class="illustration-stroke"
            stroke-width="1.5"
        ></path>
        <path
            d="M430 40 L430 54 M510 30 L510 14 L530 14"
            class="illustration-stroke"
            stroke-width="1.5"
        ></path>
    </g>

    <g class="circuit-doodle__nodes">
        <circle cx="60" cy="30" r="3.5" fill="currentColor"></circle>
        <circle cx="130" cy="20" r="2.5" fill="currentColor"></circle>
        <circle cx="160" cy="50" r="3" fill="currentColor"></circle>
        <circle cx="240" cy="30" r="3.5" fill="currentColor"></circle>
        <circle cx="340" cy="30" r="3.5" fill="currentColor"></circle>
        <circle cx="430" cy="54" r="3" fill="currentColor"></circle>
        <circle cx="500" cy="40" r="2.5" fill="currentColor"></circle>
        <circle cx="530" cy="14" r="3" fill="currentColor"></circle>
        <circle cx="70" cy="6" r="2.5" fill="currentColor"></circle>
    </g>

    <g class="circuit-doodle__splat" transform="translate(290 30)">
        <path
            d="M-22 -2 Q-26 4, -20 8 Q-12 14, -6 10 Q0 14, 6 8 Q14 12, 18 4 Q24 -4, 16 -8 Q10 -14, 2 -10 Q-6 -14, -10 -8 Q-18 -12, -22 -2 Z"
            fill="currentColor"
        ></path>
        <circle cx="-30" cy="-8" r="2" fill="currentColor"></circle>
        <circle cx="26" cy="10" r="1.6" fill="currentColor"></circle>
        <circle cx="20" cy="-12" r="1.2" fill="currentColor"></circle>
        <circle cx="-26" cy="14" r="1.4" fill="currentColor"></circle>
    </g>
</svg>

<style>
    .circuit-doodle {
        color: var(--accent);
        width: 100%;
        height: auto;
        display: block;
        opacity: 0.85;
    }

    .circuit-doodle__lines {
        opacity: 0.6;
    }
</style>
