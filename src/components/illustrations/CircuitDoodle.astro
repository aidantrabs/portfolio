---
interface Props {
    class?: string | undefined;
}

const { class: className = '' } = Astro.props;
---

<svg
    viewBox="0 0 600 24"
    preserveAspectRatio="none"
    class:list={['illustration', 'circuit-doodle', className]}
    aria-hidden="true"
    focusable="false"
    xmlns="http://www.w3.org/2000/svg"
>
    <g stroke="currentColor" stroke-width="1" stroke-linecap="square" fill="none">
        <line x1="0" y1="12" x2="180" y2="12"></line>
        <line x1="220" y1="12" x2="380" y2="12"></line>
        <line x1="420" y1="12" x2="600" y2="12"></line>
    </g>

    <g fill="currentColor">
        <rect x="180" y="9" width="6" height="6"></rect>
        <rect x="214" y="9" width="6" height="6"></rect>
        <rect x="380" y="9" width="6" height="6"></rect>
        <rect x="414" y="9" width="6" height="6"></rect>
    </g>

    <g stroke="currentColor" stroke-width="1" stroke-linecap="square" fill="none" opacity="0.45">
        <line x1="80" y1="12" x2="80" y2="4"></line>
        <line x1="80" y1="4" x2="92" y2="4"></line>
        <line x1="298" y1="12" x2="298" y2="20"></line>
        <line x1="298" y1="20" x2="320" y2="20"></line>
        <line x1="500" y1="12" x2="500" y2="4"></line>
        <line x1="500" y1="4" x2="520" y2="4"></line>
    </g>

    <g fill="currentColor" opacity="0.7">
        <circle cx="80" cy="4" r="1.5"></circle>
        <circle cx="92" cy="4" r="1.5"></circle>
        <circle cx="298" cy="20" r="1.5"></circle>
        <circle cx="320" cy="20" r="1.5"></circle>
        <circle cx="500" cy="4" r="1.5"></circle>
        <circle cx="520" cy="4" r="1.5"></circle>
    </g>
</svg>

<style>
    .circuit-doodle {
        color: var(--text);
        width: 100%;
        height: auto;
        display: block;
        opacity: 0.7;
    }

    .dark .circuit-doodle {
        opacity: 0.55;
    }
</style>
