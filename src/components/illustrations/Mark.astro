---
interface Props {
    class?: string | undefined;
    variant?: 'hero' | 'silhouette' | 'icon' | undefined;
}
const { class: className = '', variant = 'hero' } = Astro.props;
---

{variant === 'hero' && (
<svg
    class:list={['mark', `mark--${variant}`, className]}
    viewBox="0 0 200 240"
    fill="none"
    aria-hidden="true"
    focusable="false"
>
    <g filter="url(#rough-soft)">
        <ellipse cx="100" cy="228" rx="46" ry="3.5" fill="currentColor" opacity="0.16" />

        <path
            d="M 56 80 C 50 50, 78 30, 100 30 C 122 30, 150 50, 144 80 C 154 110, 148 150, 138 180 C 130 204, 116 220, 100 220 C 84 220, 70 204, 62 180 C 52 150, 46 110, 56 80 Z"
            fill="var(--accent-emphasis)"
        />
        <path
            d="M 56 80 C 50 50, 78 30, 100 30 C 122 30, 150 50, 144 80 C 154 110, 148 150, 138 180 C 130 204, 116 220, 100 220 C 84 220, 70 204, 62 180 C 52 150, 46 110, 56 80 Z"
            fill="url(#halftone)"
            color="rgba(0,0,0,1)"
            opacity="0.28"
        />
        <path
            d="M 56 80 C 50 50, 78 30, 100 30 C 122 30, 150 50, 144 80 C 154 110, 148 150, 138 180 C 130 204, 116 220, 100 220 C 84 220, 70 204, 62 180 C 52 150, 46 110, 56 80 Z"
            fill="none"
            stroke="currentColor"
            stroke-width="2.4"
            stroke-linejoin="round"
        />

        <circle cx="84" cy="98" r="6" fill="currentColor" />
        <circle cx="116" cy="98" r="6" fill="currentColor" />
        <circle cx="86" cy="95.5" r="1.8" fill="var(--bg)" />
        <circle cx="118" cy="95.5" r="1.8" fill="var(--bg)" />

        <path
            d="M 88 122 C 92 132, 108 132, 112 122"
            fill="none"
            stroke="currentColor"
            stroke-width="2.4"
            stroke-linecap="round"
        />

        <circle cx="64" cy="118" r="8" fill="#ff8470" opacity="0.55" />
        <circle cx="136" cy="118" r="8" fill="#ff8470" opacity="0.55" />

        <line
            x1="100"
            y1="30"
            x2="96"
            y2="12"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
        />
        <circle cx="95" cy="9" r="4" fill="var(--accent-emphasis)" stroke="currentColor" stroke-width="1.6" />
    </g>
</svg>
)}

{variant === 'icon' && (
<svg
    class:list={['mark', 'mark--icon', className]}
    viewBox="0 0 50 60"
    fill="none"
    aria-hidden="true"
    focusable="false"
>
    <g filter="url(#rough-soft)">
        <path
            d="M 14 20 C 12 12, 20 8, 25 8 C 30 8, 38 12, 36 20 C 38 28, 37 38, 34 45 C 32 51, 28 55, 25 55 C 22 55, 18 51, 16 45 C 13 38, 12 28, 14 20 Z"
            fill="var(--accent-emphasis)"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linejoin="round"
        />
        <circle cx="21" cy="25" r="2" fill="currentColor" />
        <circle cx="29" cy="25" r="2" fill="currentColor" />
        <path d="M 22 32 C 24 35, 26 35, 28 32" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
        <line x1="25" y1="8" x2="24" y2="3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
    </g>
</svg>
)}

{variant === 'silhouette' && (
<svg
    class:list={['mark', 'mark--silhouette', className]}
    viewBox="0 0 60 72"
    fill="none"
    aria-hidden="true"
    focusable="false"
>
    <g filter="url(#rough-soft)">
        <path
            d="M 18 24 C 14 14, 24 8, 30 8 C 36 8, 46 14, 42 24 C 46 32, 44 44, 40 54 C 36 62, 32 66, 30 66 C 28 66, 24 62, 20 54 C 16 44, 14 32, 18 24 Z"
            fill="currentColor"
        />
        <circle cx="25" cy="30" r="2.4" fill="var(--bg)" />
        <circle cx="35" cy="30" r="2.4" fill="var(--bg)" />
    </g>
</svg>
)}
