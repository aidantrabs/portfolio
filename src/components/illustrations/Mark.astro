---
interface Props {
    class?: string | undefined;
    variant?: 'hero' | 'silhouette' | 'icon' | undefined;
}
const { class: className = '', variant = 'hero' } = Astro.props;
---

{variant === 'hero' && (
<svg
    class:list={['mark', `mark--${variant}`, className]}
    viewBox="0 0 200 320"
    fill="none"
    aria-hidden="true"
    focusable="false"
>
    <g filter="url(#rough-soft)">
        <ellipse cx="100" cy="306" rx="46" ry="4" fill="currentColor" opacity="0.16" />

        <path
            d="M 84 56 C 80 36, 120 32, 124 56 C 134 66, 142 84, 142 110 C 142 142, 138 178, 136 214 C 134 246, 130 274, 124 290 C 118 300, 102 302, 88 296 C 76 290, 70 274, 70 254 C 70 222, 74 188, 76 154 C 78 124, 80 96, 80 78 C 80 70, 82 62, 84 56 Z"
            fill="var(--accent-emphasis)"
        />
        <path
            d="M 84 56 C 80 36, 120 32, 124 56 C 134 66, 142 84, 142 110 C 142 142, 138 178, 136 214 C 134 246, 130 274, 124 290 C 118 300, 102 302, 88 296 C 76 290, 70 274, 70 254 C 70 222, 74 188, 76 154 C 78 124, 80 96, 80 78 C 80 70, 82 62, 84 56 Z"
            fill="url(#halftone)"
            color="rgba(0,0,0,1)"
            opacity="0.28"
        />
        <path
            d="M 84 56 C 80 36, 120 32, 124 56 C 134 66, 142 84, 142 110 C 142 142, 138 178, 136 214 C 134 246, 130 274, 124 290 C 118 300, 102 302, 88 296 C 76 290, 70 274, 70 254 C 70 222, 74 188, 76 154 C 78 124, 80 96, 80 78 C 80 70, 82 62, 84 56 Z"
            fill="none"
            stroke="currentColor"
            stroke-width="2.2"
            stroke-linejoin="round"
        />

        <circle cx="94" cy="108" r="3.4" fill="currentColor" />
        <circle cx="118" cy="108" r="3.4" fill="currentColor" />
        <circle cx="95" cy="106.8" r="1" fill="var(--bg)" />
        <circle cx="119" cy="106.8" r="1" fill="var(--bg)" />

        <path
            d="M 100 128 C 104 134, 112 134, 116 128"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
        />

        <circle cx="82" cy="124" r="6" fill="#ff8470" opacity="0.55" />
        <circle cx="130" cy="124" r="6" fill="#ff8470" opacity="0.55" />

        <line
            x1="104"
            y1="32"
            x2="100"
            y2="14"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
        />
        <circle cx="99" cy="11" r="3.5" fill="var(--accent-emphasis)" stroke="currentColor" stroke-width="1.6" />
    </g>
</svg>
)}

{variant === 'icon' && (
<svg
    class:list={['mark', 'mark--icon', className]}
    viewBox="0 0 40 64"
    fill="none"
    aria-hidden="true"
    focusable="false"
>
    <g filter="url(#rough-soft)">
        <path
            d="M 14 12 C 12 6, 28 4, 28 12 C 32 16, 34 22, 32 32 C 30 44, 30 52, 26 58 C 22 62, 14 60, 12 54 C 10 44, 12 32, 12 22 C 12 18, 12 14, 14 12 Z"
            fill="var(--accent-emphasis)"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linejoin="round"
        />
        <circle cx="17" cy="24" r="1.5" fill="currentColor" />
        <circle cx="24" cy="24" r="1.5" fill="currentColor" />
        <path d="M 18 30 C 20 32, 22 32, 24 30" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
        <line x1="20" y1="4" x2="20" y2="0" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
    </g>
</svg>
)}

{variant === 'silhouette' && (
<svg
    class:list={['mark', 'mark--silhouette', className]}
    viewBox="0 0 48 80"
    fill="none"
    aria-hidden="true"
    focusable="false"
>
    <g filter="url(#rough-soft)">
        <path
            d="M 18 14 C 16 8, 32 6, 32 14 C 36 18, 38 26, 36 38 C 34 50, 34 60, 30 68 C 26 74, 18 72, 16 64 C 14 52, 16 38, 16 26 C 16 20, 16 16, 18 14 Z"
            fill="currentColor"
        />
        <circle cx="20" cy="30" r="1.8" fill="var(--bg)" />
        <circle cx="28" cy="30" r="1.8" fill="var(--bg)" />
    </g>
</svg>
)}
