---
interface Props {
    class?: string | undefined;
}

const { class: className = '' } = Astro.props;
---

<svg
    class:list={['illustration', 'hero-scene', className]}
    viewBox="0 0 280 360"
    aria-hidden="true"
    focusable="false"
    xmlns="http://www.w3.org/2000/svg"
>
    <g class="hero-scene__grid" stroke="currentColor" stroke-width="0.6" opacity="0.18">
        <line x1="0" y1="60" x2="280" y2="60"></line>
        <line x1="0" y1="120" x2="280" y2="120"></line>
        <line x1="0" y1="180" x2="280" y2="180"></line>
        <line x1="0" y1="240" x2="280" y2="240"></line>
        <line x1="0" y1="300" x2="280" y2="300"></line>
        <line x1="70" y1="0" x2="70" y2="360"></line>
        <line x1="140" y1="0" x2="140" y2="360"></line>
        <line x1="210" y1="0" x2="210" y2="360"></line>
    </g>

    <g class="hero-scene__crosshairs" stroke="currentColor" stroke-width="1.4" stroke-linecap="round">
        <g transform="translate(20 20)">
            <line x1="-8" y1="0" x2="8" y2="0"></line>
            <line x1="0" y1="-8" x2="0" y2="8"></line>
        </g>
        <g transform="translate(260 20)">
            <line x1="-8" y1="0" x2="8" y2="0"></line>
            <line x1="0" y1="-8" x2="0" y2="8"></line>
        </g>
        <g transform="translate(20 340)">
            <line x1="-8" y1="0" x2="8" y2="0"></line>
            <line x1="0" y1="-8" x2="0" y2="8"></line>
        </g>
        <g transform="translate(260 340)">
            <line x1="-8" y1="0" x2="8" y2="0"></line>
            <line x1="0" y1="-8" x2="0" y2="8"></line>
        </g>
    </g>

    <g class="hero-scene__measure" stroke="currentColor" stroke-width="0.8" opacity="0.4">
        <line x1="36" y1="20" x2="244" y2="20"></line>
        <line x1="36" y1="17" x2="36" y2="23"></line>
        <line x1="244" y1="17" x2="244" y2="23"></line>
        <line x1="20" y1="36" x2="20" y2="324"></line>
        <line x1="17" y1="36" x2="23" y2="36"></line>
        <line x1="17" y1="324" x2="23" y2="324"></line>
    </g>

    <g class="hero-scene__speed" stroke="currentColor" stroke-width="1" opacity="0.55">
        <line x1="84" y1="282" x2="232" y2="98"></line>
        <line x1="78" y1="296" x2="226" y2="112"></line>
        <line x1="92" y1="276" x2="240" y2="92"></line>
    </g>

    <g class="hero-scene__tag">
        <path
            d="M70 304 Q 90 270, 130 232 Q 170 196, 200 156 Q 222 124, 234 88"
            fill="none"
            stroke="currentColor"
            stroke-width="11"
            stroke-linecap="round"
            stroke-linejoin="round"
        ></path>
    </g>

    <g class="hero-scene__nodes" fill="currentColor">
        <circle cx="70" cy="304" r="3.5"></circle>
        <circle cx="234" cy="88" r="3.5"></circle>
    </g>

    <g class="hero-scene__detail" stroke="currentColor" stroke-width="1.2" stroke-linecap="round">
        <line x1="246" y1="68" x2="262" y2="68"></line>
        <line x1="254" y1="60" x2="254" y2="76"></line>
        <line x1="18" y1="284" x2="34" y2="284"></line>
        <line x1="26" y1="276" x2="26" y2="292"></line>
    </g>

    <g class="hero-scene__label" fill="currentColor" font-family="ui-monospace, SFMono-Regular, Menlo, monospace" font-size="9" letter-spacing="2" opacity="0.55">
        <text x="32" y="14">tag.001 / 2026-05-08</text>
        <text x="32" y="354">26.40n / 71.00w</text>
    </g>
</svg>

<style>
    .hero-scene {
        color: var(--text);
        width: 100%;
        height: auto;
        max-width: 360px;
    }

    .hero-scene__tag {
        color: var(--accent);
    }

    .hero-scene__nodes {
        color: var(--accent);
    }

    .hero-scene__crosshairs {
        color: var(--text);
    }
</style>
