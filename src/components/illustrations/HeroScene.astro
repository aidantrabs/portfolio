---
interface Props {
    class?: string | undefined;
}

const { class: className = '' } = Astro.props;
---

<svg
    class:list={['illustration', 'hero-scene', className]}
    viewBox="0 0 360 280"
    aria-hidden="true"
    focusable="false"
    xmlns="http://www.w3.org/2000/svg"
>
    <g class="hero-scene__meta" stroke="currentColor" fill="currentColor">
        <line x1="20" y1="14" x2="148" y2="14" stroke-width="0.7" opacity="0.5"></line>
        <line x1="212" y1="14" x2="340" y2="14" stroke-width="0.7" opacity="0.5"></line>
        <text x="156" y="17" font-family="ui-monospace, SFMono-Regular, Menlo, monospace" font-size="9" letter-spacing="2" font-weight="500" text-anchor="middle">TAPE.001 / SIDE A / 90 MIN</text>
        <circle cx="20" cy="14" r="2" />
        <circle cx="340" cy="14" r="2" />
    </g>

    <g class="hero-scene__cassette">
        <rect
            x="20"
            y="40"
            width="320"
            height="220"
            rx="14"
            ry="14"
            fill="var(--bg-elevated)"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linejoin="round"
        ></rect>

        <path
            d="M150 40 L150 50 Q150 54 154 54 L206 54 Q210 54 210 50 L210 40"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linejoin="round"
        ></path>

        <g class="hero-scene__screws" stroke="currentColor" stroke-width="1" fill="none">
            <g transform="translate(36 56)">
                <circle r="3.5" fill="var(--bg)" stroke-width="1.4"></circle>
                <line x1="-2.5" y1="-2.5" x2="2.5" y2="2.5"></line>
            </g>
            <g transform="translate(324 56)">
                <circle r="3.5" fill="var(--bg)" stroke-width="1.4"></circle>
                <line x1="-2.5" y1="-2.5" x2="2.5" y2="2.5"></line>
            </g>
            <g transform="translate(36 244)">
                <circle r="3.5" fill="var(--bg)" stroke-width="1.4"></circle>
                <line x1="-2.5" y1="-2.5" x2="2.5" y2="2.5"></line>
            </g>
            <g transform="translate(324 244)">
                <circle r="3.5" fill="var(--bg)" stroke-width="1.4"></circle>
                <line x1="-2.5" y1="-2.5" x2="2.5" y2="2.5"></line>
            </g>
            <g transform="translate(180 134)">
                <circle r="3.5" fill="var(--bg)" stroke-width="1.4"></circle>
                <line x1="-2.5" y1="-2.5" x2="2.5" y2="2.5"></line>
            </g>
        </g>

        <g class="hero-scene__label">
            <rect
                x="50"
                y="60"
                width="260"
                height="50"
                rx="3"
                ry="3"
                fill="none"
                stroke="currentColor"
                stroke-width="1.4"
            ></rect>
            <line x1="50" y1="78" x2="310" y2="78" stroke="currentColor" stroke-width="1"></line>
            <text x="58" y="74" font-family="ui-monospace, SFMono-Regular, Menlo, monospace" font-size="9" font-weight="600" letter-spacing="2" fill="currentColor">AIDAN_TAPE</text>
            <text x="302" y="74" font-family="ui-monospace, SFMono-Regular, Menlo, monospace" font-size="8" letter-spacing="1.5" fill="currentColor" text-anchor="end" opacity="0.6">A / 26-05-08</text>
            <line x1="58" y1="88" x2="180" y2="88" stroke="currentColor" stroke-width="0.7" opacity="0.4"></line>
            <line x1="58" y1="94" x2="220" y2="94" stroke="currentColor" stroke-width="0.7" opacity="0.4"></line>
            <line x1="58" y1="100" x2="160" y2="100" stroke="currentColor" stroke-width="0.7" opacity="0.4"></line>
            <rect x="262" y="86" width="44" height="20" fill="none" stroke="currentColor" stroke-width="0.8" opacity="0.5"></rect>
            <text x="284" y="100" font-family="ui-monospace, SFMono-Regular, Menlo, monospace" font-size="11" font-weight="700" fill="currentColor" text-anchor="middle">90</text>
        </g>

        <rect
            x="50"
            y="118"
            width="260"
            height="118"
            rx="3"
            ry="3"
            fill="var(--bg)"
            stroke="currentColor"
            stroke-width="1.4"
        ></rect>

        <g class="hero-scene__tape">
            <line x1="124" y1="170" x2="236" y2="170" stroke="currentColor" stroke-width="2.4"></line>
            <line x1="124" y1="174" x2="236" y2="174" stroke="currentColor" stroke-width="0.8" opacity="0.5"></line>
            <line x1="124" y1="178" x2="236" y2="178" stroke="currentColor" stroke-width="0.6" opacity="0.3"></line>
        </g>

        <g class="hero-scene__reel hero-scene__reel--left" transform="translate(110 176)">
            <circle r="40" fill="var(--bg-elevated)" stroke="currentColor" stroke-width="2.2"></circle>
            <circle r="32" fill="none" stroke="currentColor" stroke-width="0.6" opacity="0.4"></circle>
            <g stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
                <line x1="14" y1="0" x2="26" y2="0"></line>
                <line x1="7" y1="-12.12" x2="13" y2="-22.52"></line>
                <line x1="-7" y1="-12.12" x2="-13" y2="-22.52"></line>
                <line x1="-14" y1="0" x2="-26" y2="0"></line>
                <line x1="-7" y1="12.12" x2="-13" y2="22.52"></line>
                <line x1="7" y1="12.12" x2="13" y2="22.52"></line>
            </g>
            <circle r="14" fill="var(--accent)" stroke="currentColor" stroke-width="1.6"></circle>
            <circle r="10" fill="none" stroke="var(--bg-elevated)" stroke-width="0.8" opacity="0.6"></circle>
            <g fill="var(--bg-elevated)">
                <rect x="-1" y="-7" width="2" height="3"></rect>
                <rect x="-1" y="4" width="2" height="3"></rect>
                <rect x="-7" y="-1" width="3" height="2"></rect>
                <rect x="4" y="-1" width="3" height="2"></rect>
            </g>
        </g>

        <g class="hero-scene__reel hero-scene__reel--right" transform="translate(250 176)">
            <circle r="40" fill="var(--bg-elevated)" stroke="currentColor" stroke-width="2.2"></circle>
            <circle r="32" fill="none" stroke="currentColor" stroke-width="0.6" opacity="0.4"></circle>
            <g stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
                <line x1="14" y1="0" x2="26" y2="0"></line>
                <line x1="7" y1="-12.12" x2="13" y2="-22.52"></line>
                <line x1="-7" y1="-12.12" x2="-13" y2="-22.52"></line>
                <line x1="-14" y1="0" x2="-26" y2="0"></line>
                <line x1="-7" y1="12.12" x2="-13" y2="22.52"></line>
                <line x1="7" y1="12.12" x2="13" y2="22.52"></line>
            </g>
            <circle r="14" fill="none" stroke="currentColor" stroke-width="1.6"></circle>
            <g fill="currentColor">
                <rect x="-1" y="-7" width="2" height="3"></rect>
                <rect x="-1" y="4" width="2" height="3"></rect>
                <rect x="-7" y="-1" width="3" height="2"></rect>
                <rect x="4" y="-1" width="3" height="2"></rect>
            </g>
        </g>

        <g class="hero-scene__sensors" stroke="currentColor" fill="currentColor">
            <rect x="60" y="244" width="3" height="6" />
            <rect x="68" y="244" width="3" height="6" />
            <rect x="290" y="244" width="3" height="6" />
            <rect x="298" y="244" width="3" height="6" />
        </g>
    </g>

    <g class="hero-scene__footer" stroke="currentColor" fill="currentColor">
        <line x1="20" y1="270" x2="92" y2="270" stroke-width="0.7" opacity="0.5"></line>
        <line x1="268" y1="270" x2="340" y2="270" stroke-width="0.7" opacity="0.5"></line>
        <text x="180" y="273" font-family="ui-monospace, SFMono-Regular, Menlo, monospace" font-size="9" letter-spacing="2" font-weight="500" text-anchor="middle">TT-26 / TRINIDAD / 26.40N 71.00W</text>
        <g transform="translate(100 266)">
            <rect x="0" y="0" width="1.5" height="8" />
            <rect x="3" y="0" width="0.8" height="8" />
            <rect x="5" y="0" width="2" height="8" />
            <rect x="9" y="0" width="0.8" height="8" />
            <rect x="11" y="0" width="1.5" height="8" />
            <rect x="14" y="0" width="2.5" height="8" />
            <rect x="18" y="0" width="0.8" height="8" />
            <rect x="20" y="0" width="1.5" height="8" />
            <rect x="23" y="0" width="2" height="8" />
            <rect x="27" y="0" width="0.8" height="8" />
            <rect x="29" y="0" width="1.5" height="8" />
            <rect x="32" y="0" width="2.5" height="8" />
            <rect x="36" y="0" width="0.8" height="8" />
            <rect x="38" y="0" width="1.5" height="8" />
            <rect x="41" y="0" width="2" height="8" />
            <rect x="45" y="0" width="0.8" height="8" />
            <rect x="47" y="0" width="2.5" height="8" />
            <rect x="51" y="0" width="0.8" height="8" />
            <rect x="53" y="0" width="1.5" height="8" />
            <rect x="56" y="0" width="2" height="8" />
            <rect x="60" y="0" width="0.8" height="8" />
            <rect x="62" y="0" width="1.5" height="8" />
            <rect x="65" y="0" width="2.5" height="8" />
        </g>
        <g transform="translate(228 266)">
            <rect x="0" y="0" width="1.5" height="8" />
            <rect x="3" y="0" width="0.8" height="8" />
            <rect x="5" y="0" width="2" height="8" />
            <rect x="9" y="0" width="0.8" height="8" />
            <rect x="11" y="0" width="1.5" height="8" />
            <rect x="14" y="0" width="2.5" height="8" />
            <rect x="18" y="0" width="0.8" height="8" />
            <rect x="20" y="0" width="1.5" height="8" />
            <rect x="23" y="0" width="2" height="8" />
            <rect x="27" y="0" width="0.8" height="8" />
            <rect x="29" y="0" width="1.5" height="8" />
            <rect x="32" y="0" width="2.5" height="8" />
        </g>
    </g>
</svg>

<style>
    .hero-scene {
        color: var(--text);
        width: 100%;
        height: auto;
        max-width: 480px;
    }
</style>
