---
interface Props {
    class?: string | undefined;
}
const { class: className = '' } = Astro.props;
---

<svg
    class:list={['signature-rack', className]}
    viewBox="0 0 320 400"
    fill="none"
    aria-hidden="true"
    focusable="false"
>
    <g class="signature-rack__strokes" filter="url(#rough-soft)">
        <rect
            x="40"
            y="30"
            width="200"
            height="280"
            rx="6"
            stroke="currentColor"
            stroke-width="2.4"
        />

        <line x1="40" y1="118" x2="240" y2="118" stroke="currentColor" stroke-width="1.6" />
        <line x1="40" y1="208" x2="240" y2="208" stroke="currentColor" stroke-width="1.6" />

        <g class="signature-rack__unit-top">
            <circle cx="62" cy="58" r="5" fill="var(--accent-emphasis)" />
            <circle cx="80" cy="58" r="3.4" stroke="currentColor" stroke-width="1.4" />
            <circle cx="96" cy="58" r="3.4" stroke="currentColor" stroke-width="1.4" />
            <line x1="120" y1="58" x2="220" y2="58" stroke="currentColor" stroke-width="1.4" />
            <line x1="120" y1="68" x2="200" y2="68" stroke="currentColor" stroke-width="1.4" stroke-dasharray="4 3" />
            <line x1="120" y1="88" x2="210" y2="88" stroke="currentColor" stroke-width="1.4" />
            <line x1="120" y1="100" x2="180" y2="100" stroke="currentColor" stroke-width="1.4" stroke-dasharray="3 4" />
        </g>

        <g class="signature-rack__unit-mid">
            <rect
                x="60"
                y="138"
                width="78"
                height="50"
                stroke="currentColor"
                stroke-width="1.4"
            />
            <rect
                x="60"
                y="138"
                width="78"
                height="50"
                fill="url(#halftone)"
                opacity="0.5"
                color="currentColor"
            />
            <circle cx="166" cy="148" r="4" fill="currentColor" />
            <circle cx="166" cy="164" r="4" stroke="currentColor" stroke-width="1.4" />
            <circle cx="166" cy="180" r="4" stroke="currentColor" stroke-width="1.4" />
            <line x1="184" y1="148" x2="220" y2="148" stroke="currentColor" stroke-width="1.4" />
            <line x1="184" y1="164" x2="220" y2="164" stroke="currentColor" stroke-width="1.4" />
            <line x1="184" y1="180" x2="208" y2="180" stroke="currentColor" stroke-width="1.4" />
        </g>

        <g class="signature-rack__unit-bot">
            <circle cx="62" cy="238" r="5" fill="var(--accent-emphasis)" />
            <line x1="80" y1="238" x2="220" y2="238" stroke="currentColor" stroke-width="1.4" />
            <line x1="60" y1="258" x2="220" y2="258" stroke="currentColor" stroke-width="1.4" stroke-dasharray="5 3" />
            <line x1="60" y1="278" x2="200" y2="278" stroke="currentColor" stroke-width="1.4" />
            <line x1="60" y1="290" x2="160" y2="290" stroke="currentColor" stroke-width="1.4" stroke-dasharray="3 4" />
        </g>

        <path
            class="signature-rack__wire"
            d="M 220 310 C 250 320, 280 330, 270 350 C 258 372, 220 372, 210 360 C 198 346, 230 332, 245 348 C 260 364, 290 372, 300 358"
            stroke="currentColor"
            stroke-width="2.2"
            stroke-linecap="round"
        />

        <g class="signature-rack__monogram" transform="translate(220, 358) rotate(-6)">
            <path
                d="M 0 26 L 8 4 L 16 26 M 4 18 L 12 18"
                stroke="var(--accent-emphasis)"
                stroke-width="2.6"
                stroke-linecap="round"
                stroke-linejoin="round"
            />
            <path
                d="M 22 4 L 38 4 M 30 4 L 30 26"
                stroke="var(--accent-emphasis)"
                stroke-width="2.6"
                stroke-linecap="round"
                stroke-linejoin="round"
            />
        </g>
    </g>
</svg>

