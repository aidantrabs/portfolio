---
interface Props {
    index: number;
    title: string;
    year: number;
    role: string;
    description: string;
    url: string;
}

const { index, title, year, role, description, url } = Astro.props;
const padded = String(index).padStart(2, '0');
---

<li class="project-row">
    <a href={url} target="_blank" rel="noopener" class="project-row__link">
        <span class="project-row__index">{padded}</span>
        <span class="project-row__meta">{year} / {role}</span>
        <h3 class="project-row__title">{title}</h3>
        <p class="project-row__desc">{description}</p>
        <span class="project-row__arrow" aria-hidden="true">↗</span>
    </a>
</li>
