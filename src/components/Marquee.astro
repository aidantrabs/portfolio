---
const REPEAT_COUNT = 16;
---

<section class="marquee-section">
    <div class="marquee-track" data-marquee-track>
        {
            Array.from({ length: REPEAT_COUNT }).map(() => (
                <span class="marquee-item">
                    let's talk <span class="marquee-sep">/</span>
                </span>
            ))
        }
    </div>

    <div class="marquee-controls">
        <button
            type="button"
            class="marquee-toggle"
            data-marquee-toggle
            aria-label="Pause marquee"
            aria-pressed="false"
        >
            <span class="marquee-toggle__icon marquee-toggle__icon--pause" aria-hidden="true">
                <svg viewBox="0 0 12 12" width="10" height="10">
                    <rect x="2" y="2" width="3" height="8" fill="currentColor"></rect>
                    <rect x="7" y="2" width="3" height="8" fill="currentColor"></rect>
                </svg>
            </span>
            <span class="marquee-toggle__icon marquee-toggle__icon--play" aria-hidden="true">
                <svg viewBox="0 0 12 12" width="10" height="10">
                    <path d="M3 2 L10 6 L3 10 Z" fill="currentColor"></path>
                </svg>
            </span>
        </button>
        <span class="marquee-time" data-marquee-time>00:00:00</span>
    </div>
</section>
