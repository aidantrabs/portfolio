---
const CATEGORIES = [
    {
        label: 'languages',
        items: ['TypeScript', 'Go', 'Python', 'Rust', 'Lua', 'SQL'],
    },
    {
        label: 'frontend',
        items: ['React', 'Svelte', 'Astro', 'Tailwind', 'Vite'],
    },
    {
        label: 'infrastructure',
        items: ['Postgres', 'Redis', 'Terraform', 'Kubernetes', 'Docker', 'Linux'],
    },
    {
        label: 'platforms',
        items: ['Cloudflare', 'AWS', 'GCP', 'Bun', 'Node', 'Nginx'],
    },
];

const total = CATEGORIES.reduce((sum, cat) => sum + cat.items.length, 0);
---

<section id="skills" class="section section--skills">
    <div class="section__header">
        <div class="section__heading">
            <span class="section__num">03</span>
            <h2 class="section__title">stack</h2>
        </div>
        <span class="section__count">
            {total}
            <span class="section__count-label">tools</span>
        </span>
    </div>

    <div class="stack-grid">
        {
            CATEGORIES.map((cat) => (
                <div class="stack-group">
                    <div class="stack-group__label">
                        <span class="stack-group__dot" />
                        <span>{cat.label}</span>
                    </div>
                    <ul class="stack-list">
                        {cat.items.map((item) => (
                            <li class="stack-tag">{item}</li>
                        ))}
                    </ul>
                </div>
            ))
        }
    </div>
</section>
