---
import CircuitDoodle from './illustrations/CircuitDoodle.astro';

const LANGS = [
    'TypeScript',
    'Go',
    'Python',
    'Rust',
    'Lua',
    'React',
    'Svelte',
    'Astro',
    'Tailwind',
    'GraphQL',
    'Node',
];
const INFRA = [
    'Postgres',
    'Redis',
    'Terraform',
    'Docker',
    'Kubernetes',
    'Linux',
    'AWS',
    'GCP',
    'Cloudflare',
    'Bun',
    'Nginx',
    'Vault',
];

const row1 = [...LANGS, ...LANGS];
const row2 = [...INFRA, ...INFRA];
const total = LANGS.length + INFRA.length;
---

<section id="skills" class="section section--skills">
    <div class="section__divider" aria-hidden="true">
        <CircuitDoodle />
    </div>

    <div class="section__header">
        <div class="section__heading">
            <span class="section__num">03</span>
            <h2 class="section__title">stack</h2>
        </div>
        <span class="section__count">
            {total}
            <span class="section__count-label">tools</span>
        </span>
    </div>

    <div class="skills-marquee skills-marquee--row1" aria-hidden="true">
        <div class="skills-marquee__track">
            {row1.map((s) => <span class="skill-chip">{s}</span>)}
        </div>
    </div>

    <div class="skills-marquee skills-marquee--row2" aria-hidden="true">
        <div class="skills-marquee__track">
            {row2.map((s) => <span class="skill-chip skill-chip--alt">{s}</span>)}
        </div>
    </div>
</section>
