---
const STACK = [
    'TypeScript',
    'Go',
    'Python',
    'Rust',
    'Postgres',
    'React',
    'Astro',
    'Tailwind',
    'Terraform',
    'Docker',
    'Kubernetes',
    'Linux',
    'AWS',
    'Cloudflare',
    'Bun',
    'Nginx',
    'Redis',
    'GraphQL',
];

const track = [...STACK, ...STACK];
---

<section id="skills" class="section section--skills">
    <div class="section__header">
        <div class="section__heading">
            <span class="section__num">03</span>
            <h2 class="section__title">stack</h2>
        </div>
        <span class="section__count">
            {STACK.length}
            <span class="section__count-label">tools</span>
        </span>
    </div>

    <div class="skills-marquee" aria-hidden="true">
        <div class="skills-marquee__track">
            {track.map((s) => <span class="skill-chip">{s}</span>)}
        </div>
    </div>
</section>
